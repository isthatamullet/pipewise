# Local-only docs and scripts — single rule covers the whole private
# surface. Add new private files here rather than to per-file gitignore lines.
.local/

# Local-only Claude convention overlay (kept at root for Claude Code to load).
CLAUDE.local.md

# Local-only Claude tooling — agents and slash commands kept project-local
# but private (sibling to CLAUDE.local.md pattern). Public-facing review
# practices live in SECURITY.md / CODE_OF_CONDUCT.md, not in tooling files.
.claude/agents/
.claude/commands/

# Archived planning transcript — grep/human reference only, do not load into Claude
*-FULL-TRANSCRIPT.txt

# Local pipewise output (generated runs, reports)
runs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual envs
.venv/
venv/

# uv
.uv/

# Test / lint / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Env files
.env
.env.*
!.env.example

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code harness runtime state
.claude/scheduled_tasks.lock
